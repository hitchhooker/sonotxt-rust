# Database
DATABASE_URL=postgres://sonotxt:sonotxt@localhost:5432/sonotxt

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Admin
ADMIN_TOKEN=your-admin-token-here

# DeepInfra TTS
DEEPINFRA_TOKEN=your-deepinfra-token-here

# VibVoice TTS (optional)
# VIBEVOICE_URL=http://localhost:5050

# MinIO/S3
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_BUCKET=sonotxt-audio

# Audio URL
# Development: http://localhost:9000/sonotxt-audio
# Production: https://audio.sonotxt.com/sonotxt-audio
AUDIO_PUBLIC_URL=http://localhost:9000/sonotxt-audio

# Billing
COST_PER_CHAR=0.0000016
COST_PER_MINUTE=0.004

# App URL (for Stripe redirects)
APP_URL=https://app.sonotxt.com

# CORS (comma-separated for production)
CORS_ORIGINS=

# Logging
RUST_LOG=info

# ─── hwpay secrets ───────────────────────────────────
# These go in /srv/sonotxt/api/.env on the production server

# Vault password (encrypted file fallback when TPM unavailable)
# VAULT_PASSWORD=your-vault-password

# Stripe (TPM-sealed via hwpay vault, or set directly)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# HD wallet seed for generating per-user deposit addresses
# hex-encoded 32 bytes, or leave unset to use TPM vault
# DEPOSIT_WALLET_SEED=deadbeef...

# ─── hwpay polkadot asset hub ────────────────────────
ASSETHUB_RPC=wss://polkadot-asset-hub-rpc.polkadot.io
ASSETHUB_USDC_ASSET_ID=1337
ASSETHUB_USDT_ASSET_ID=1984
ASSETHUB_LISTENER_ENABLED=false

# Auto-sweep to medium wallet (optional)
# ASSETHUB_MEDIUM_WALLET=your-ss58-address

# ─── hwpay penumbra (optional) ───────────────────────
# PENUMBRA_RPC=https://grpc.penumbra.zone
# PENUMBRA_SPEND_KEY=penumbraspendkey1...
# PCLI_CONFIG_PATH=~/.local/share/pcli/config.toml

# ─── email (magic link auth) ─────────────────────────
# JMAP_URL=https://jmap.example.com
# JMAP_USER=noreply@sonotxt.com
# JMAP_PASS=your-jmap-password
JMAP_FROM=noreply@sonotxt.com

# ─── embed widget ────────────────────────────────────
# EMBED_SECRET=your-hmac-secret
EMBED_DAILY_LIMIT=50000
